#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STATE_DIR="${VIBE_LOCAL_STATE_DIR:-$ROOT/.vibe-local}"
LOG_DIR="$STATE_DIR/logs"
PID_DIR="$STATE_DIR/pids"
DATA_ROOT="${VIBE_DATA_ROOT:-/Users/pengying/workspace/ai-finance-os/vibe-data}"
LOCAL_HOME="$STATE_DIR/home"

BACKEND_HOST="${VIBE_BACKEND_HOST:-127.0.0.1}"
BACKEND_PORT="${VIBE_BACKEND_PORT:-8899}"
MCP_HOST="${VIBE_MCP_HOST:-127.0.0.1}"
MCP_PORT="${VIBE_MCP_PORT:-8900}"
POSTGRES_HOST="${POSTGRES_HOST:-127.0.0.1}"
POSTGRES_PORT="${POSTGRES_PORT:-5432}"
POSTGRES_DB="${POSTGRES_DB:-vibe_trading}"
POSTGRES_USER="${POSTGRES_USER:-vibe}"
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-vibe_dev_password}"

if [[ -n "${PYTHON:-}" ]]; then
  PYTHON_BIN="$PYTHON"
elif [[ -x "$ROOT/.venv311/bin/python" ]]; then
  PYTHON_BIN="$ROOT/.venv311/bin/python"
elif [[ -x "$ROOT/.venv/bin/python" ]]; then
  PYTHON_BIN="$ROOT/.venv/bin/python"
elif [[ -x "$ROOT/agent/.venv/bin/python" ]]; then
  PYTHON_BIN="$ROOT/agent/.venv/bin/python"
else
  PYTHON_BIN="python3"
fi

mkdir -p "$LOG_DIR" "$PID_DIR"

if [[ -f "$ROOT/agent/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT/agent/.env"
  set +a
fi

POSTGRES_HOST="${POSTGRES_HOST:-127.0.0.1}"
POSTGRES_PORT="${POSTGRES_PORT:-5432}"
POSTGRES_DB="${POSTGRES_DB:-vibe_trading}"
POSTGRES_USER="${POSTGRES_USER:-vibe}"
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-vibe_dev_password}"
DATABASE_URL="${DATABASE_URL:-${VIBE_DATABASE_URL:-postgresql+psycopg://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST:$POSTGRES_PORT/$POSTGRES_DB}}"

usage() {
  cat <<USAGE
Usage: scripts/local-services <command>

Commands:
  start              Start Postgres, backend, and MCP SSE services
  backend            Start backend only, after preparing Postgres
  mcp                Start MCP SSE only
  mcp-stdio          Run MCP server in stdio mode in the foreground
  mcp-config         Print MCP client config examples
  mcp-test           Smoke test MCP stdio and SSE endpoints
  postgres           Start local Postgres via docker compose
  stop               Stop services started by this script
  restart            Restart Postgres, backend, and MCP SSE services
  status             Show process status and URLs
  logs [service]     Tail logs: backend, mcp, or all
  urls               Print local URLs

Environment:
  VIBE_BACKEND_HOST  Backend bind host (default: 127.0.0.1)
  VIBE_BACKEND_PORT  Backend port (default: 8899)
  VIBE_MCP_HOST      MCP SSE bind host (default: 127.0.0.1)
  VIBE_MCP_PORT      MCP SSE port (default: 8900)
  VIBE_DATA_ROOT     Runtime data root (default: /Users/pengying/workspace/ai-finance-os/vibe-data)
  DATABASE_URL       Portfolio DB URL (default: postgresql+psycopg://vibe:...@127.0.0.1:5432/vibe_trading)
  POSTGRES_*         Local Postgres connection fields used when DATABASE_URL is not set
  PYTHON             Python binary (default: .venv/bin/python, then python3)
USAGE
}

pid_file() {
  printf "%s/%s.pid" "$PID_DIR" "$1"
}

log_file() {
  printf "%s/%s.log" "$LOG_DIR" "$1"
}

is_running() {
  local service="$1"
  local file
  file="$(pid_file "$service")"
  if ! [[ -f "$file" ]]; then
    return 1
  fi
  local pid
  pid="$(cat "$file")"
  kill -0 "$pid" 2>/dev/null || lsof -nP -p "$pid" >/dev/null 2>&1
}

port_open() {
  "$PYTHON_BIN" - "$1" "$2" >/dev/null 2>&1 <<'PY' || lsof -nP -iTCP:"$2" -sTCP:LISTEN >/dev/null 2>&1
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
with socket.create_connection((host, port), timeout=1):
    pass
PY
}

url_ok() {
  local url="$1"
  if command -v curl >/dev/null 2>&1; then
    curl -fsS --max-time 2 "$url" >/dev/null 2>&1
  else
    "$PYTHON_BIN" - "$url" >/dev/null 2>&1 <<'PY'
import sys
import urllib.request

urllib.request.urlopen(sys.argv[1], timeout=2).read(1)
PY
  fi
}

link_data_dir() {
  local path="$1"
  local target="$2"
  local backup_root="$STATE_DIR/backups"
  mkdir -p "$(dirname "$path")" "$target" "$backup_root"

  if [[ -L "$path" ]]; then
    local current
    current="$(readlink "$path")"
    if [[ "$current" == "$target" ]]; then
      return 0
    fi
    mv "$path" "$backup_root/$(basename "$path").symlink.$(date +%Y%m%d%H%M%S)"
  elif [[ -e "$path" ]]; then
    if [[ -d "$path" ]]; then
      if find "$path" -mindepth 1 -maxdepth 1 | read -r _; then
        cp -a "$path"/. "$target"/
      fi
      mv "$path" "$backup_root/$(basename "$path").dir.$(date +%Y%m%d%H%M%S)"
    else
      mv "$path" "$backup_root/$(basename "$path").file.$(date +%Y%m%d%H%M%S)"
    fi
  fi

  ln -s "$target" "$path"
}

prepare_data_root() {
  mkdir -p \
    "$DATA_ROOT/runs" \
    "$DATA_ROOT/sessions" \
    "$DATA_ROOT/uploads" \
    "$DATA_ROOT/swarm-runs" \
    "$DATA_ROOT/postgres" \
    "$DATA_ROOT/home" \
    "$LOCAL_HOME"

  link_data_dir "$ROOT/agent/runs" "$DATA_ROOT/runs"
  link_data_dir "$ROOT/agent/sessions" "$DATA_ROOT/sessions"
  link_data_dir "$ROOT/agent/uploads" "$DATA_ROOT/uploads"
  link_data_dir "$ROOT/agent/.swarm/runs" "$DATA_ROOT/swarm-runs"
  link_data_dir "$LOCAL_HOME/.vibe-trading" "$DATA_ROOT/home"
}

ensure_python_deps() {
  if "$PYTHON_BIN" - >/dev/null 2>&1 <<'PY'
import sqlalchemy
import psycopg
PY
  then
    return 0
  fi

  cat >&2 <<DEPS
Missing local Python DB dependencies required by Investment Workspace:
  - SQLAlchemy
  - psycopg

Install them into this environment, for example:
  $PYTHON_BIN -m pip install -e "$ROOT"

Then rerun:
  scripts/local-services restart
DEPS
  return 1
}

start_service() {
  local service="$1"
  shift
  if is_running "$service"; then
    printf "%s already running (pid %s)\n" "$service" "$(cat "$(pid_file "$service")")"
    return 0
  fi

  printf "starting %s...\n" "$service"
  "$PYTHON_BIN" - "$(log_file "$service")" "$(pid_file "$service")" "$@" <<'PY'
import subprocess
import sys

log_path = sys.argv[1]
pid_path = sys.argv[2]
cmd = sys.argv[3:]

log = open(log_path, "ab", buffering=0)
proc = subprocess.Popen(
    cmd,
    stdin=subprocess.DEVNULL,
    stdout=log,
    stderr=subprocess.STDOUT,
    start_new_session=True,
    close_fds=True,
)
with open(pid_path, "w", encoding="utf-8") as fh:
    fh.write(str(proc.pid))
PY
  printf "%s pid %s, log %s\n" "$service" "$(cat "$(pid_file "$service")")" "$(log_file "$service")"
}

stop_service() {
  local service="$1"
  local file
  file="$(pid_file "$service")"
  if ! [[ -f "$file" ]]; then
    printf "%s not started by scripts/local-services\n" "$service"
    return 0
  fi

  local pid
  pid="$(cat "$file")"
  if kill -0 "$pid" 2>/dev/null; then
    printf "stopping %s (pid %s)...\n" "$service" "$pid"
    kill -TERM "-$pid" 2>/dev/null || kill "$pid" 2>/dev/null || true
    sleep 0.5
    kill -KILL "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  fi
  rm -f "$file"
}

wait_for_backend() {
  printf "waiting for backend at http://%s:%s/health" "$BACKEND_HOST" "$BACKEND_PORT"
  for _ in $(seq 1 30); do
    if url_ok "http://$BACKEND_HOST:$BACKEND_PORT/health"; then
      printf " ready\n"
      return 0
    fi
    if ! is_running backend; then
      printf "\nbackend exited early; see %s\n" "$(log_file backend)" >&2
      return 1
    fi
    printf "."
    sleep 1
  done
  printf "\nbackend not ready; see %s\n" "$(log_file backend)" >&2
  return 1
}

wait_for_postgres() {
  printf "waiting for postgres at %s:%s" "$POSTGRES_HOST" "$POSTGRES_PORT"
  for _ in $(seq 1 45); do
    if port_open "$POSTGRES_HOST" "$POSTGRES_PORT"; then
      printf " ready\n"
      return 0
    fi
    printf "."
    sleep 1
  done
  printf "\npostgres not ready at %s:%s\n" "$POSTGRES_HOST" "$POSTGRES_PORT" >&2
  return 1
}

wait_for_mcp() {
  printf "waiting for mcp at %s:%s" "$MCP_HOST" "$MCP_PORT"
  for _ in $(seq 1 30); do
    if port_open "$MCP_HOST" "$MCP_PORT"; then
      printf " ready\n"
      return 0
    fi
    if ! is_running mcp; then
      printf "\nmcp exited early; see %s\n" "$(log_file mcp)" >&2
      return 1
    fi
    printf "."
    sleep 1
  done
  printf "\nmcp not ready; see %s\n" "$(log_file mcp)" >&2
  return 1
}

start_backend() {
  prepare_data_root
  ensure_python_deps
  start_postgres
  if ! is_running backend && url_ok "http://$BACKEND_HOST:$BACKEND_PORT/health"; then
    rm -f "$(pid_file backend)"
    printf "backend already reachable at http://%s:%s/health (external)\n" "$BACKEND_HOST" "$BACKEND_PORT"
    return 0
  fi
  start_service backend env HOME="$LOCAL_HOME" PYTHONPATH="$ROOT/agent" DATABASE_URL="$DATABASE_URL" "$PYTHON_BIN" -c 'import cli, sys; raise SystemExit(cli.main(sys.argv[1:]))' serve \
    --host "$BACKEND_HOST" \
    --port "$BACKEND_PORT"
}

start_postgres() {
  prepare_data_root
  if port_open "$POSTGRES_HOST" "$POSTGRES_PORT"; then
    printf "postgres already reachable at %s:%s\n" "$POSTGRES_HOST" "$POSTGRES_PORT"
    return 0
  fi
  if ! command -v docker >/dev/null 2>&1; then
    printf "docker is required to start local postgres, or set DATABASE_URL to an existing database\n" >&2
    return 1
  fi
  printf "starting postgres via docker compose...\n"
  VIBE_DATA_ROOT="$DATA_ROOT" docker compose -f "$ROOT/docker-compose.yml" up -d postgres
  wait_for_postgres
}

start_mcp() {
  prepare_data_root
  if ! is_running mcp && port_open "$MCP_HOST" "$MCP_PORT"; then
    rm -f "$(pid_file mcp)"
    printf "mcp already reachable at http://%s:%s/sse (external)\n" "$MCP_HOST" "$MCP_PORT"
    return 0
  fi
  start_service mcp env HOME="$LOCAL_HOME" PYTHONPATH="$ROOT/agent" "$PYTHON_BIN" "$ROOT/agent/mcp_server.py" \
    --transport sse \
    --host "$MCP_HOST" \
    --port "$MCP_PORT"
}

cmd_start() {
  start_postgres
  start_backend
  start_mcp
  wait_for_postgres
  wait_for_backend
  wait_for_mcp
  cmd_urls
}

cmd_stop() {
  stop_service mcp
  stop_service backend
}

cmd_status() {
  if port_open "$POSTGRES_HOST" "$POSTGRES_PORT"; then
    printf "%-8s reachable url=%s\n" postgres "$DATABASE_URL"
  else
    printf "%-8s stopped url=%s\n" postgres "$DATABASE_URL"
  fi

  if is_running backend; then
    printf "%-8s running pid=%s log=%s\n" backend "$(cat "$(pid_file backend)")" "$(log_file backend)"
  elif url_ok "http://$BACKEND_HOST:$BACKEND_PORT/health"; then
    printf "%-8s reachable external url=http://%s:%s/health\n" backend "$BACKEND_HOST" "$BACKEND_PORT"
  else
    printf "%-8s stopped\n" backend
  fi

  if is_running mcp; then
    printf "%-8s running pid=%s log=%s\n" mcp "$(cat "$(pid_file mcp)")" "$(log_file mcp)"
  elif port_open "$MCP_HOST" "$MCP_PORT"; then
    printf "%-8s reachable external url=http://%s:%s/sse\n" mcp "$MCP_HOST" "$MCP_PORT"
  else
    printf "%-8s stopped\n" mcp
  fi
  cmd_urls
}

cmd_mcp_stdio() {
  prepare_data_root
  ensure_python_deps
  exec env HOME="$LOCAL_HOME" PYTHONPATH="$ROOT/agent" "$PYTHON_BIN" "$ROOT/agent/mcp_server.py" --transport stdio
}

cmd_mcp_config() {
  cat <<CONFIG
MCP SSE:
  http://$MCP_HOST:$MCP_PORT/sse

Claude Desktop / stdio:
{
  "mcpServers": {
    "vibe-trading": {
      "command": "$ROOT/scripts/local-services",
      "args": ["mcp-stdio"]
    }
  }
}

OpenClaw / stdio:
skills:
  - name: vibe-trading
    command: $ROOT/scripts/local-services
    args:
      - mcp-stdio

Local all-in-one:
  $ROOT/scripts/local-services start
CONFIG
}

cmd_mcp_test() {
  printf "testing MCP stdio: "
  if printf '{"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}}\n' | timeout 5 env HOME="$LOCAL_HOME" PYTHONPATH="$ROOT/agent" "$PYTHON_BIN" "$ROOT/agent/mcp_server.py" --transport stdio 2>/dev/null | grep -q '"result"'; then
    printf "ok\n"
  else
    printf "failed or timed out\n"
  fi
  printf "testing MCP SSE %s:%s: " "$MCP_HOST" "$MCP_PORT"
  if port_open "$MCP_HOST" "$MCP_PORT"; then
    printf "ok\n"
  else
    printf "not reachable\n"
  fi
}

cmd_logs() {
  local service="${1:-all}"
  case "$service" in
    backend|mcp)
      touch "$(log_file "$service")"
      tail -f "$(log_file "$service")"
      ;;
    all)
      touch "$(log_file backend)" "$(log_file mcp)"
      tail -f "$(log_file backend)" "$(log_file mcp)"
      ;;
    *)
      printf "unknown service: %s\n" "$service" >&2
      exit 2
      ;;
  esac
}

cmd_urls() {
  cat <<URLS
Backend:  http://$BACKEND_HOST:$BACKEND_PORT
API docs: http://$BACKEND_HOST:$BACKEND_PORT/docs
MCP SSE:  http://$MCP_HOST:$MCP_PORT/sse
Logs:     $LOG_DIR
Data:     $DATA_ROOT
DB:       $DATABASE_URL
URLS
}

case "${1:-}" in
  start) cmd_start ;;
  backend) start_backend; wait_for_backend; cmd_urls ;;
  mcp) start_mcp; wait_for_mcp; cmd_urls ;;
  mcp-stdio) cmd_mcp_stdio ;;
  mcp-config) cmd_mcp_config ;;
  mcp-test) cmd_mcp_test ;;
  postgres) start_postgres ;;
  stop) cmd_stop ;;
  restart) cmd_stop; cmd_start ;;
  status) cmd_status ;;
  logs) shift; cmd_logs "${1:-all}" ;;
  urls) cmd_urls ;;
  -h|--help|help|"") usage ;;
  *)
    printf "unknown command: %s\n\n" "$1" >&2
    usage >&2
    exit 2
    ;;
esac
